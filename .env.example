# ============================================================
# AyudaVE — Variables de entorno (ejemplo)
# Copia este archivo a .env y rellena los valores. NUNCA subas tu .env real.
# En LOCAL puedes dejar casi todo vacío: arranca con SQLite y sin dependencias externas.
# Los valores marcados [PROD] son obligatorios en producción.
# ============================================================

# ── App ──
PORT=4599                      # puerto del servidor
BUILD=                         # versión para cache-busting de JS/CSS (en deploy se setea, p.ej. un timestamp)

# ── Base de datos ──
# Vacío = SQLite local (data/ayudave.db). En producción: Postgres (Cloud SQL).
DATABASE_URL=                  # p.ej. postgres://usuario:CLAVE@host:5432/ayudave  (o socket Cloud SQL)
PGSSL=                         # "off" para desactivar SSL en Postgres
PG_POOL=5                      # tamaño del pool de conexiones

# ── Almacenamiento de imágenes ──
GCS_BUCKET=                    # bucket de Google Cloud Storage. Vacío = disco local (data/uploads)

# ── Seguridad / administración ──
AYUDAVE_PIN_PEPPER=            # [PROD] secreto para el hash de PIN. Genera uno fuerte y NO lo cambies (cambiarlo invalida los PIN existentes)
AYUDAVE_ADMINS=+584140000001   # teléfonos admin separados por coma (EJEMPLO ficticio — pon los tuyos)
AYUDAVE_IMPORT_TOKEN=          # token para la ingesta colaborativa (POST /api/admin/ingest). Vacío = endpoint desactivado
AYUDAVE_METRICS_SALT=          # sal para anonimizar visitantes (sin guardar IP). Recomendado fijarla en prod

# ── Asistente con IA (buscar persona por foto) ──
AYUDAVE_GEMINI_KEY=            # API key de Google AI Studio. Vacío = la búsqueda por foto queda desactivada (solo por nombre)
AYUDAVE_GEMINI_MODEL=gemini-2.5-flash   # modelo de Gemini a usar

# ── Mapa y analítica (opcionales) ──
AYUDAVE_GOOGLE_MAPS_KEY=       # API key de Google Maps. Vacío = usa Leaflet/OpenStreetMap (sin key)
AYUDAVE_GA_ID=                 # ID de Google Analytics (opcional)

# ── Datos de ejemplo ──
AYUDAVE_SEED=                  # "on" para cargar centros/personas de ejemplo al iniciar

# ── Fuentes externas (auto-sincronización; todas opcionales) ──
ACOPIO_IMPORT=on               # "off" para desactivar la importación de centros de acopio
ACOPIO_SHEET_URL=              # URL de la fuente (sheet2api) de centros de acopio. Vacío = no importa
ACOPIO_REFRESH_MIN=10          # minutos entre refrescos de acopio
REPORTES_URL=                  # API de reportes de servicios (default: ve.crafter.run/api/reports)
EDIF_API=                      # API de edificios afectados (terremotovenezuela.com)
OCR_HOSPITALS_CSV=             # CSV de pacientes en hospitales (fuente OCR)
DTV_API=                       # API de desaparecidos del sismo
DTV_PROXY=                     # proxy opcional para la API de desaparecidos
AUDIT_ON_REFRESH=              # "on" para auditar duplicados tras cada refresco
AUDIT_MIN_MINUTES=             # minutos mínimos entre auditorías
